    "babel-loader": "^9.1.3",
    "babel-plugin-module-resolver": "^5.0.0",
    "compression-webpack-plugin": "^10.0.0",
    "eslint": "^8.19.0",
    "html-webpack-plugin": "^5.6.0",
    "husky": "^8.0.3",
    "lint-staged": "^15.2.0",
    "prettier": "2.8.8",
    "typescript": "5.0.4",
    "url-loader": "^4.1.1",
